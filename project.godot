; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Topographic Map"
config/description="Depth-based topographic map post-process on an orthographic top-down camera."
run/main_scene="res://TopoDemo/scenes/DemoMinimap.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[dotnet]

project/assembly_name="TopographicMap"

